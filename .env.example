# Required
DISCORD_WEBHOOK_URL=replace-with-your-discord-webhook-url

# Polling and posting
CHECK_INTERVAL=300
POST_DELAY=3
COOLDOWN_DELAY=60

# Embed text limits. MAX_POST_LENGTH caps combined visible embed text for
# compatibility; MAX_CONTENT_LENGTH caps the cleaned article summary.
MAX_POST_LENGTH=1900
MAX_CONTENT_LENGTH=800
FEED_TIMEOUT=30
INITIAL_SYNC_MODE=skip
INITIAL_SYNC_MAX_POSTS=1
MAX_ENTRIES_PER_FEED=20
MAX_POSTS_PER_CYCLE=10
MAX_CONCURRENT_FEEDS=5
POST_RETENTION_DAYS=365
MAX_FEED_BYTES=10485760
DISCORD_MAX_RETRIES=5
LOG_LEVEL=info
LOG_FORMAT=text
HEALTH_MAX_AGE=0

# Data
RSS_BOT_DATA=/app/data
# DB_FILE=/app/data/posted_hashes.db

# Universal feeds take priority when set.
# RSS_FEEDS=https://example.com/rss,https://example.org/feed

# Category feeds are used when RSS_FEEDS is not set.
# RSS_FEEDS_NEWS=https://g1.globo.com/dynamo/rss2.xml,https://rss.uol.com.br/feed/noticias.xml
# RSS_FEEDS_TECHNOLOGY=https://canaltech.com.br/rss/,https://rss.tecmundo.com.br/feed
# RSS_FEEDS_SPORTS=https://globoesporte.globo.com/rss/ultimas/
# RSS_FEEDS_BUSINESS=https://www.infomoney.com.br/rss/
# RSS_FEEDS_POLITICS=https://www.gazetadopovo.com.br/feed/rss/republica.xml

# Deprecated compatibility variables accepted by v3 but ignored for logging/PID management:
# RSS_BOT_LOGS=/app/logs
# LOG_FILE=/app/logs/rss_bot.log
# RSS_BOT_PID=/tmp/discord-rss-bot.pid
